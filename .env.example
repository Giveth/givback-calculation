# HTTP Basic Auth for the GIVbacks admin/reporting endpoints.
# Required for the donation/report routes (e.g. /calculate, /calculate-updated,
# /eligible-donations, /purpleList, /givDumpers, /givbacks-round-report).
# Leave ADMIN_EXPORT_PASSWORD unset to fail closed (all guarded routes return 401).
ADMIN_EXPORT_USERNAME=admin
